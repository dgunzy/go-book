{{define "content"}}
<section class="not-found section-shell">
  <p class="eyebrow dark">404</p>
  <h1>That page is out of bounds.</h1>
  <p>The page may have moved, or the address may be incorrect.</p>
  <a class="primary-link dark-button" href="/">Return home <span aria-hidden="true">&rarr;</span></a>
</section>
{{end}}
